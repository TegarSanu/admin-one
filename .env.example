# Database Configuration
DATABASE_URL=mongodb://localhost:27017/admin-dashboard
MONGODB_URI=mongodb://localhost:27017/admin-dashboard

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Payment Gateway - Midtrans
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_SERVER_KEY=your-midtrans-server-key

# Payment Gateway - Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Payment Gateway - DOKU
DOKU_MERCHANT_ID=your-doku-merchant-id
DOKU_API_KEY=your-doku-api-key

# Shipping Integration - JNE
JNE_API_KEY=your-jne-api-key

# Shipping Integration - TIKI
TIKI_API_KEY=your-tiki-api-key

# Shipping Integration - Grab
GRAB_API_KEY=your-grab-api-key

# Shipping Integration - Pos Indonesia
POS_API_KEY=your-pos-api-key

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@marketplace.com

# SMS Integration - Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# WhatsApp Integration
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-account-id
WHATSAPP_BUSINESS_PHONE_ID=your-whatsapp-phone-id
WHATSAPP_BUSINESS_ACCESS_TOKEN=your-whatsapp-token

# AWS Configuration (optional, for file uploads)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Tax Configuration
DEFAULT_TAX_RATE=0.1
ENABLE_TAX_CALCULATION=true

# Shipping Configuration
DEFAULT_SHIPPING_COST=50000
FREE_SHIPPING_THRESHOLD=500000

# Order Configuration
ORDER_TIMEOUT_MINUTES=30
AUTO_CANCEL_UNPAID_ORDERS=true

# Refund Configuration
AUTO_REFUND_TIMEOUT_DAYS=30
ENABLE_PARTIAL_REFUND=true
